generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  FARMER
  PROVIDER
  VETERINARIAN
  ADMIN
}

enum BookingStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AIFeatureType {
  CROP_ASSISTANT
  RECOMMENDATION
  CONTENT_GENERATOR
  DATA_ANALYZER
}

// Core Models
model User {
  id               String         @id @default(cuid())
  name             String
  email            String         @unique
  password         String
  phone            String?        @unique
  location         String?
  avatar           String?
  role             Role           @default(FARMER)
  isVerified       Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  bookingsAsFarmer Booking[]      @relation("FarmerBookings")
  reviews          Review[]
  aiQueries        AIQuery[]
  notifications    Notification[]
  blogs            Blog[]
  
  specialistProfile SpecialistProfile?
  appointments      Appointment[]      @relation("FarmerAppointments")
}

model SpecialistProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  
  specialization  String  
  qualifications  String   
  registrationNo  String   
  experienceYears Int
  consultationFee Float
  bio             String?
  
  appointments    Appointment[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Appointment {
  id              String           @id @default(cuid())
  farmerId        String
  specialistId    String
  status          BookingStatus    @default(PENDING)
  appointmentDate DateTime
  problemDesc     String?          
  meetingLink     String?          
  
  farmer          User             @relation("FarmerAppointments", fields: [farmerId], references: [id])
  specialist      SpecialistProfile @relation(fields: [specialistId], references: [id])
  
  createdAt       DateTime         @default(now())
}

model Provider {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String
  phone       String?   @unique
  location    String?
  avatar      String?
  role        Role      @default(PROVIDER)
  isVerified  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  equipment        Equipment[]    @relation("ProviderEquipment")
  bookingsAsProvider Booking[]      @relation("ProviderBookings")
  reviews          Review[]
  aiQueries        AIQuery[]
  notifications    Notification[]
  blogs            Blog[]         
}


model Equipment {
  id            String    @id @default(cuid())
  title         String
  description   String
  pricePerDay   Float
  location      String
  availability  Boolean   @default(true)
  rating        Float     @default(0) // Logic: Average of Review ratings
  images        String[]
  categoryId    String
  providerId    String

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  provider      Provider  @relation("ProviderEquipment", fields: [providerId], references: [id])
  category      Category  @relation(fields: [categoryId], references: [id])
  bookings      Booking[]
  reviews       Review[]

  @@index([location])
  @@index([categoryId])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  icon        String?

  equipment   Equipment[]
}

model Booking {
  id            String        @id @default(cuid())
  farmerId      String
  equipmentId   String
  providerId    String?
  status        BookingStatus @default(PENDING)
  startDate     DateTime
  endDate       DateTime
  totalPrice    Float
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  farmer        User          @relation("FarmerBookings", fields: [farmerId], references: [id])
  provider      Provider?     @relation("ProviderBookings", fields: [providerId], references: [id])
  equipment     Equipment     @relation(fields: [equipmentId], references: [id])
}

model Review {
  id          String   @id @default(cuid())
  rating      Int      // 1-5
  comment     String?
  userId      String?
  providerId  String?
  equipmentId String
  createdAt   DateTime @default(now())

  user        User?     @relation(fields: [userId], references: [id])
  provider    Provider? @relation(fields: [providerId], references: [id])
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
}

model AIQuery {
  id          String        @id @default(cuid())
  userId      String?
  providerId  String?
  prompt      String
  response    String
  featureType AIFeatureType
  createdAt   DateTime      @default(now())

  user        User?         @relation(fields: [userId], references: [id])
  provider    Provider?     @relation(fields: [providerId], references: [id])
}

enum BlogCategory {
  RICE
  WHEAT
  POTATO
  VEGETABLE
  FRUIT
  SOIL
  FERTILIZER
  OTHER
}

enum BlogStatus {
  DRAFT
  PUBLISHED
}

model Blog {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  content     String       // HTML or MDX
  excerpt     String?
  image       String?
  category    BlogCategory @default(OTHER)
  status      BlogStatus   @default(DRAFT)
  authorId    String?
  providerId  String?
  authorName  String
  authorEmail String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  author      User?         @relation(fields: [authorId], references: [id])
  provider    Provider?     @relation(fields: [providerId], references: [id])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String?
  providerId  String?
  title       String
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User?     @relation(fields: [userId], references: [id])
  provider    Provider? @relation(fields: [providerId], references: [id])
}